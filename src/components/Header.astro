---
const navItems = [
  { label: 'Home', href: '/' },
  { 
    label: 'About', 
    href: '#',
    dropdown: [
      { label: 'Siva Nadi Astrology', href: '/siva-nadi-astrology' },
      { label: 'Nadi Astrology History', href: '/nadi-astrology-history' },
      { label: 'Nadi Astrology Procedure', href: '/nadi-astrology-procedure' },
      { label: 'Online Nadi Astrology Procedure', href: '/online-nadi-astrology-procedure' }
    ]
  },
  {
    label: 'Nadi Astrology',
    href: '#',
    dropdown: [
      { label: 'Original Nadi Jothidam', href: '/original-nadi-jothidam' },
      { label: 'Accurate Nadi Jothidam', href: '/accurate-nadi-jothidam' },
      { label: 'Genuine Astrologer', href: '/genuine-astrologer' }
    ]
  },
  { label: 'Guruji', href: '/guruji-thillaimani' },
  {
    label: 'Locations',
    href: '#',
    dropdown: [
      { label: 'Vaitheeswaran Koil', href: '/vaitheeswaran-koil' },
      { label: 'Trichy', href: '/trichy' }
    ]
  },
  {
    label: 'Languages',
    href: '#',
    dropdown: [
      { label: 'Tamil', href: '/nadi-astrology-tamil' },
      { label: 'English', href: '/nadi-astrology-english' },
      { label: 'Hindi', href: '/nadi-astrology-hindi' },
      { label: 'Malayalam', href: '/nadi-astrology-malayalam' },
      { label: 'Telugu', href: '/nadi-astrology-telugu' }
    ]
  },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Contact', href: '/contact' }
];
---

<header class="bg-white shadow-md sticky top-0 z-50">
  <div class="container mx-auto px-4">
    <div class="flex items-center py-4">
      <div class="flex items-center flex-shrink-0">
        <a href="/" class="text-2xl font-bold text-primary">
          Sree Agasthiya Maha Siva Nadi
        </a>
      </div>
      
      <nav class="hidden lg:flex items-center space-x-2 mx-auto">
        {navItems.map(item => (
          item.dropdown ? (
            <div class="relative group">
              <button class="px-4 py-2 rounded-lg text-gray-700 hover:text-primary hover:bg-amber-50 transition-all duration-300 ease-in-out font-medium">
                {item.label}
                <svg class="inline w-4 h-4 ml-1 transform group-hover:rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="absolute left-0 mt-2 w-64 bg-white rounded-xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 -translate-y-2 overflow-hidden">
                {item.dropdown.map(subItem => (
                  <a href={subItem.href} class="block px-5 py-3 text-sm text-gray-700 hover:bg-gradient-to-r hover:from-amber-50 hover:to-orange-50 hover:text-primary transition-all duration-200 border-b border-gray-50 last:border-b-0">
                    {subItem.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} class="px-4 py-2 rounded-lg text-gray-700 hover:text-primary hover:bg-amber-50 transition-all duration-300 ease-in-out font-medium">
              {item.label}
            </a>
          )
        ))}
      </nav>
      
      <div class="flex items-center space-x-4 ml-auto">
        <a href="tel:+919500639334" class="hidden md:flex items-center text-primary hover:text-secondary">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          +91 95006 39334
        </a>
        <a href="https://www.facebook.com/share/1Cujtc6h5C/" target="_blank" rel="noopener noreferrer" class="hidden md:flex text-blue-600 hover:text-blue-700" aria-label="Visit our Facebook page">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/guruj_ma.thillaimani?igsh=MWhhZTZ6NHU1dThxNA==" target="_blank" rel="noopener noreferrer" class="hidden md:flex text-pink-600 hover:text-pink-700" aria-label="Visit our Instagram page">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
        <button id="mobile-menu-button" class="lg:hidden text-gray-700">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-gradient-to-br from-amber-50 to-orange-50 border-t border-gray-200">
    <nav class="container mx-auto px-4 py-4 space-y-2">
      {navItems.map(item => (
        <div>
          <a href={item.href} class="block py-3 px-4 text-gray-700 hover:text-primary hover:bg-white rounded-lg transition-all duration-200 font-medium shadow-sm">
            {item.label}
          </a>
          {item.dropdown && (
            <div class="pl-4 space-y-1 mt-2">
              {item.dropdown.map(subItem => (
                <a href={subItem.href} class="block py-2 px-4 text-sm text-gray-600 hover:text-primary hover:bg-white rounded-lg transition-all duration-200">
                  {subItem.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
