---
const features = [
  {
    icon: '🏆',
    title: '25+ Experience',
    description: 'Over 25 years of expertise in Nadi Astrology'
  },
  {
    icon: '🕐',
    title: '24x7 Availability',
    description: 'Round-the-clock service for your convenience'
  },
  {
    icon: '🌍',
    title: 'Instant Access Worldwide',
    description: 'Online consultations available globally'
  },
  {
    icon: '✨',
    title: 'Accurate Remedial Solutions',
    description: 'Precise predictions and effective remedies'
  },
  {
    icon: '🔒',
    title: 'Privacy Guaranteed',
    description: 'Your information is completely confidential'
  },
  {
    icon: '👥',
    title: 'Trusted by Ten Thousand Clients',
    description: 'Thousands of satisfied clients worldwide'
  }
];
---

<section class="py-16 bg-gradient-to-br from-primary to-secondary text-white">
  <div class="container mx-auto px-4">
    <h2 class="text-4xl font-bold text-center mb-12">Why Choose Us?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map(feature => (
        <div class="text-center bg-white/10 backdrop-blur-sm p-6 rounded-lg hover:bg-white/20 transition-all">
          <div class="text-5xl mb-4">{feature.icon}</div>
          <h3 class="text-xl font-bold mb-2">{feature.title}</h3>
          <p class="text-gray-100">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
