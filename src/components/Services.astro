---
const services = [
  { name: 'Agasthiya Nadi', image: '/assets/images/nadi/1.png' },
  { name: 'Siva Nadi', image: '/assets/images/nadi/2.jpg' },
  { name: 'Bhrigu Nadi', image: '/assets/images/nadi/3.jpg' },
  { name: 'Kaushika Nadi', image: '/assets/images/nadi/4.jpg' },
  { name: 'Vashista Nadi', image: '/assets/images/nadi/5.jpg' },
  { name: 'Bogar Nadi', image: '/assets/images/nadi/6.jpg' }
];
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-4xl font-bold text-center mb-4 text-gray-800">About Nadi Astrology Center Services In Trichy</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 mt-12">
      {services.map(service => (
        <div class="text-center group">
          <div class="mb-4 overflow-hidden rounded-lg">
            <img 
              src={service.image} 
              alt={service.name}
              class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-300"
            />
          </div>
          <h3 class="font-semibold text-gray-800">{service.name}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
