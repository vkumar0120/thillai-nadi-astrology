---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Nadi Astrology in Malayalam - നാടി ജ്യോതിഷം">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-8 text-gray-800">
          നാടി ജ്യോതിഷം (Nadi Jyothisham in Malayalam)
        </h1>
        
        <p class="text-xl text-center text-gray-600 mb-12">
          മലയാളത്തിൽ നാടി ജ്യോതിഷ സേവനങ്ങൾ
        </p>
        
        <div class="space-y-8 text-lg leading-relaxed">
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8 text-gray-700">
            <p class="mb-4">
              നാടി ജ്യോതിഷം പ്രാചീന ഋഷിമാർ എഴുതിയ ഓല ഗ്രന്ഥങ്ങളിൽ സൂക്ഷിച്ചിരിക്കുന്ന ഭാവി പ്രവചനങ്ങളെ അടിസ്ഥാനമാക്കിയുള്ള ഒരു ദൈവിക ജ്യോതിഷ വിദ്യയാണ്.
            </p>
            <p>
              വൈദ്യേശ്വരൻ കോയിലിലെ നാടി ജ്യോതിഷ കേന്ദ്രം ഏറ്റവും പ്രസിദ്ധമാണ്. ഇവിടെ അഗസ്ത്യ മഹർഷിയും മറ്റ് സിദ്ധന്മാരും എഴുതിയ ഓല ഗ്രന്ഥങ്ങൾ സൂക്ഷിച്ചിരിക്കുന്നു.
            </p>
          </div>
          
          <div class="bg-white border-2 border-primary rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">ഞങ്ങളുടെ സേവനങ്ങൾ</h2>
            <ul class="space-y-3 text-gray-700">
              <li>✓ അഗസ്ത്യ നാടി ജ്യോതിഷം</li>
              <li>✓ ശിവ നാടി ജ്യോതിഷം</li>
              <li>✓ ഭൃഗു നാടി ജ്യോതിഷം</li>
              <li>✓ ഓൺലൈൻ മലയാളത്തിൽ പരാമർശം</li>
              <li>✓ പരിഹാര പൂജകൾ</li>
              <li>✓ ജീവിത മാർഗനിർദേശം</li>
            </ul>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">നാടി ജ്യോതിഷം എങ്ങനെ പ്രവർത്തിക്കുന്നു?</h2>
            <p class="text-gray-700 mb-4">
              നിങ്ങളുടെ തള്ളവിരലിന്റെ മുദ്രയുടെ അടിസ്ഥാനത്തിൽ നിങ്ങൾക്കായുള്ള ഓല കണ്ടെത്തുന്നു. പിന്നീട് ആ ഓലയിൽ എഴുതിയിരിക്കുന്ന വിവരങ്ങൾ മലയാളത്തിൽ വായിച്ച് വിശദീകരിക്കുന്നു.
            </p>
            <p class="text-gray-700">
              മുൻജന്മ കർമ്മങ്ങൾ, നിലവിലെ ജീവിത സാഹചര്യങ്ങൾ, ഭാവി പ്രവചനങ്ങൾ, പരിഹാര മാർഗങ്ങൾ എന്നിവ വിശദമായി പറയുന്നു.
            </p>
          </div>
          
          <div class="bg-primary text-white rounded-lg p-8 text-center">
            <h2 class="text-2xl font-bold mb-4">ബന്ധപ്പെടുക</h2>
            <p class="mb-6">നിങ്ങളുടെ നാടി ജ്യോതിഷ പരാമർശത്തിനായി ഇന്ന് തന്നെ ബന്ധപ്പെടുക</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="tel:+919500639334" class="bg-white text-primary px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition-colors">
                വിളിക്കുക: +91 95006 39334
              </a>
              <a href="/contact" class="border-2 border-white text-white px-8 py-3 rounded-full font-semibold hover:bg-white hover:text-primary transition-colors">
                സന്ദേശം അയക്കുക
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
