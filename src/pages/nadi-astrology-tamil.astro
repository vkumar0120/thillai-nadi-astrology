---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Nadi Astrology in Tamil - நாடி ஜோதிடம்">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-8 text-gray-800">
          நாடி ஜோதிடம் (Nadi Jothidam in Tamil)
        </h1>
        
        <p class="text-xl text-center text-gray-600 mb-12">
          தமிழில் நாடி ஜோதிட சேவைகள்
        </p>
        
        <div class="space-y-8 text-lg leading-relaxed">
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8">
            <p class="text-gray-700 mb-4">
              நாடி ஜோதிடம் என்பது பண்டைய காலத்து ரிஷிகள் எழுதிய ஓலைச்சுவடிகளில் உள்ள நம் வாழ்க்கை பற்றிய முன்னறிவிப்புகளை அறிந்து கொள்ளும் ஒரு தெய்வீக முறையாகும்.
            </p>
            <p class="text-gray-700">
              வைத்தீஸ்வரன் கோவிலில் உள்ள நாடி ஜோதிட மையம் மிகவும் பிரபலமானது. இங்கு அகஸ்தியர், சிவரிஷி மற்றும் பல மகான்கள் எழுதிய நாடி ஓலைச்சுவடிகள் பாதுகாக்கப்பட்டு வருகின்றன.
            </p>
          </div>
          
          <div class="bg-white border-2 border-primary rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">எங்கள் சேவைகள்</h2>
            <ul class="space-y-3 text-gray-700">
              <li>✓ அகஸ்தியர் நாடி ஜோதிடம்</li>
              <li>✓ சிவ நாடி ஜோதிடம்</li>
              <li>✓ பிருகு நாடி ஜோதிடம்</li>
              <li>✓ கௌசிக நாடி ஜோதிடம்</li>
              <li>✓ வசிஷ்ட நாடி ஜோதிடம்</li>
              <li>✓ போகர் நாடி ஜோதிடம்</li>
            </ul>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">நாடி ஜோதிடம் எவ்வாறு செயல்படுகிறது?</h2>
            <p class="text-gray-700 mb-4">
              உங்கள் கட்டை விரல் ரேகையின் அடிப்படையில் உங்களுக்கான ஓலைச்சுவடி கண்டுபிடிக்கப்படும். பின்னர் அந்த ஓலையில் உள்ள தகவல்கள் தமிழில் படித்து விளக்கப்படும்.
            </p>
            <p class="text-gray-700">
              கடந்த கால நிகழ்வுகள், நிகழ்கால சூழ்நிலைகள், எதிர்கால கணிப்புகள் மற்றும் பரிகார வழிமுறைகள் விரிவாக கூறப்படும்.
            </p>
          </div>
          
          <div class="bg-primary text-white rounded-lg p-8 text-center">
            <h2 class="text-2xl font-bold mb-4">தொடர்பு கொள்ள</h2>
            <p class="mb-6">உங்கள் நாடி ஜோதிட பார்வைக்கு இன்றே தொடர்பு கொள்ளுங்கள்</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="tel:+919500639334" class="bg-white text-primary px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition-colors">
                அழைக்க: +91 95006 39334
              </a>
              <a href="/contact" class="border-2 border-white text-white px-8 py-3 rounded-full font-semibold hover:bg-white hover:text-primary transition-colors">
                தொடர்பு படிவம்
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
