---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Accurate Nadi Jothidam - Genuine Palm Leaf Readings">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Accurate Nadi Jothidam
        </h1>
        
        <div class="space-y-8 text-gray-700">
          <p class="text-lg leading-relaxed">
            Accuracy is the cornerstone of authentic Nadi Astrology. Our center at Vaitheeswaran Koil ensures that every reading is conducted with precision and genuine care for the seeker's spiritual journey.
          </p>
          
          <div class="bg-primary/10 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">How We Ensure Accuracy</h2>
            <div class="space-y-4">
              <div class="flex items-start">
                <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center font-bold mr-4 flex-shrink-0">
                  1
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2">Authentic Palm Leaves</h3>
                  <p>We use only original ancient palm leaf manuscripts preserved from generations</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center font-bold mr-4 flex-shrink-0">
                  2
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2">Expert Readers</h3>
                  <p>Our Nadi readers have 25+ years of experience in interpreting the ancient scripts</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center font-bold mr-4 flex-shrink-0">
                  3
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2">Thumb Impression Matching</h3>
                  <p>Scientific identification through unique thumb print patterns</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center font-bold mr-4 flex-shrink-0">
                  4
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2">Detailed Verification</h3>
                  <p>Multiple verification steps to ensure the correct palm leaf is identified</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center font-bold mr-4 flex-shrink-0">
                  5
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2">Remedial Solutions</h3>
                  <p>Precise and effective remedies based on your specific life situations</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">What Our Accuracy Means for You</h2>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <span>Clear insights into your past life events with remarkable precision</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <span>Detailed predictions about your future with specific timelines</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <span>Personality analysis that helps you understand yourself better</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <span>Targeted remedies that actually work for your specific challenges</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <span>Spiritual guidance aligned with your unique karmic path</span>
              </li>
            </ul>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors">
            Get Your Accurate Reading
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
