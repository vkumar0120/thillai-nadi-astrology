---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Nadi Astrology in English - Complete Consultation Services">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Nadi Astrology Services in English
        </h1>
        
        <div class="space-y-8 text-gray-700 text-lg leading-relaxed">
          <p>
            We provide comprehensive Nadi Astrology consultations in English for clients from around the world. Our expert readers are fluent in English and ensure that every detail from your palm leaf reading is accurately translated and explained.
          </p>
          
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">English Consultation Services</h2>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Complete palm leaf reading in English</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Detailed explanation of predictions and their meanings</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Remedial solutions explained clearly</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Q&A session in English</span>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">•</span>
                <span>Written summary of key predictions available</span>
              </li>
            </ul>
          </div>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-white border-2 border-primary rounded-lg p-6">
              <h3 class="text-xl font-bold text-primary mb-4">For International Clients</h3>
              <p>Easily accessible via phone or video call with interpretation in clear English</p>
            </div>
            <div class="bg-white border-2 border-primary rounded-lg p-6">
              <h3 class="text-xl font-bold text-primary mb-4">For Indian Diaspora</h3>
              <p>Connect with your roots through authentic Nadi readings in English</p>
            </div>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors">
            Book English Consultation
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
