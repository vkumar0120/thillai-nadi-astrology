---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Online Nadi Astrology Procedure - Virtual Consultation">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Online Nadi Astrology Procedure
        </h1>
        
        <p class="text-lg text-gray-700 text-center mb-12 leading-relaxed">
          Get authentic Nadi Astrology readings from the comfort of your home, anywhere in the world
        </p>
        
        <div class="space-y-6">
          <div class="bg-gradient-to-r from-primary/10 to-transparent border-l-4 border-primary p-6 rounded">
            <div class="flex items-start">
              <div class="bg-primary text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mr-4 flex-shrink-0">
                1
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-2 text-gray-800">Initial Contact</h3>
                <p class="text-gray-700">
                  Contact us via phone (+91 95006 39334), WhatsApp, or email to schedule your online consultation. Provide your basic details and preferred date and time for the reading.
                </p>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-r from-primary/10 to-transparent border-l-4 border-primary p-6 rounded">
            <div class="flex items-start">
              <div class="bg-primary text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mr-4 flex-shrink-0">
                2
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-2 text-gray-800">Submit Thumb Impression</h3>
                <p class="text-gray-700">
                  Take a clear photo or scan of your thumb impression (right thumb for males, left for females) and send it to us via WhatsApp or email. Our team will guide you on how to capture a clear impression.
                </p>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-r from-primary/10 to-transparent border-l-4 border-primary p-6 rounded">
            <div class="flex items-start">
              <div class="bg-primary text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mr-4 flex-shrink-0">
                3
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-2 text-gray-800">Palm Leaf Search</h3>
                <p class="text-gray-700">
                  Our expert Nadi readers will search for your palm leaf using your thumb impression. This process may take a few hours to a few days depending on the complexity of finding your specific leaf.
                </p>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-r from-primary/10 to-transparent border-l-4 border-primary p-6 rounded">
            <div class="flex items-start">
              <div class="bg-primary text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mr-4 flex-shrink-0">
                4
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-2 text-gray-800">Online Verification Session</h3>
                <p class="text-gray-700">
                  We'll schedule a video call or phone consultation where the Nadi reader verifies your identity by reading general information. You'll confirm details about yourself and family members until the correct leaf is identified.
                </p>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-r from-primary/10 to-transparent border-l-4 border-primary p-6 rounded">
            <div class="flex items-start">
              <div class="bg-primary text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mr-4 flex-shrink-0">
                5
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-2 text-gray-800">Complete Reading</h3>
                <p class="text-gray-700">
                  Once verified, you'll receive your complete Nadi reading including past life details, present circumstances, future predictions, and specific remedial solutions. The session typically lasts 60-90 minutes.
                </p>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-r from-primary/10 to-transparent border-l-4 border-primary p-6 rounded">
            <div class="flex items-start">
              <div class="bg-primary text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mr-4 flex-shrink-0">
                6
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-2 text-gray-800">Recording & Follow-up</h3>
                <p class="text-gray-700">
                  We can provide an audio/video recording of your reading for future reference. Follow-up consultations are available if you need clarification or additional guidance on remedies.
                </p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bg-green-50 border-2 border-green-500 rounded-lg p-8 mt-12">
          <h2 class="text-2xl font-bold mb-4 text-gray-800 text-center">Benefits of Online Consultation</h2>
          <div class="grid md:grid-cols-2 gap-4 text-gray-700">
            <div class="flex items-start">
              <span class="text-green-600 text-2xl mr-3">✓</span>
              <span>Access from anywhere in the world</span>
            </div>
            <div class="flex items-start">
              <span class="text-green-600 text-2xl mr-3">✓</span>
              <span>Same accuracy as in-person readings</span>
            </div>
            <div class="flex items-start">
              <span class="text-green-600 text-2xl mr-3">✓</span>
              <span>Convenient scheduling</span>
            </div>
            <div class="flex items-start">
              <span class="text-green-600 text-2xl mr-3">✓</span>
              <span>Recording available for later review</span>
            </div>
            <div class="flex items-start">
              <span class="text-green-600 text-2xl mr-3">✓</span>
              <span>No travel required</span>
            </div>
            <div class="flex items-start">
              <span class="text-green-600 text-2xl mr-3">✓</span>
              <span>Multilingual support available</span>
            </div>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors">
            Schedule Online Consultation
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
