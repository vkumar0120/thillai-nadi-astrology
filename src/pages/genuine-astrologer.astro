---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Genuine Astrologer - Authentic Nadi Readings">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Genuine Nadi Astrologer
        </h1>
        
        <div class="space-y-8 text-gray-700 text-lg leading-relaxed">
          <p>
            Finding a genuine Nadi astrologer is crucial for accurate and authentic palm leaf readings. With over 25 years of experience and thousands of satisfied clients, our center stands as a beacon of authenticity in the field of Nadi Astrology.
          </p>
          
          <div class="bg-primary/10 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">What Makes an Astrologer Genuine?</h2>
            <ul class="space-y-4">
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <div>
                  <strong>Authentic Palm Leaves:</strong> Works with original ancient manuscripts, not reproductions or fabricated texts
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <div>
                  <strong>Lineage & Training:</strong> Learned the art from traditional masters with proper training in reading ancient Tamil script
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <div>
                  <strong>Accurate Past Revelations:</strong> Can accurately describe your past events without any prior information
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <div>
                  <strong>Transparent Process:</strong> Follows proper thumb impression matching and verification steps
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <div>
                  <strong>Privacy Assured:</strong> Maintains strict confidentiality of all personal information
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-primary text-2xl mr-3">✓</span>
                <div>
                  <strong>Ethical Practice:</strong> Provides honest readings without exaggeration or fear-mongering
                </div>
              </li>
            </ul>
          </div>
          
          <div class="bg-gradient-to-br from-secondary/20 to-primary/20 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">Our Credentials</h2>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-white p-6 rounded-lg shadow-md">
                <div class="text-4xl font-bold text-primary mb-2">25+</div>
                <p class="text-gray-800 font-semibold">Years of Experience</p>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-md">
                <div class="text-4xl font-bold text-primary mb-2">10,000+</div>
                <p class="text-gray-800 font-semibold">Satisfied Clients</p>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-md">
                <div class="text-4xl font-bold text-primary mb-2">24x7</div>
                <p class="text-gray-800 font-semibold">Availability</p>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-md">
                <div class="text-4xl font-bold text-primary mb-2">100%</div>
                <p class="text-gray-800 font-semibold">Privacy Guaranteed</p>
              </div>
            </div>
          </div>
          
          <div class="border-l-4 border-primary pl-6 py-4 bg-primary/5">
            <p class="text-xl font-semibold text-gray-800 mb-2">
              "A genuine astrologer empowers you with knowledge, not fear. Our readings illuminate your path with compassion and accuracy."
            </p>
            <p class="text-gray-600">- Guruji Thillaimani</p>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors">
            Experience Genuine Nadi Astrology
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
