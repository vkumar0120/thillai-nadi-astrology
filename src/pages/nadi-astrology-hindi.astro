---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Nadi Astrology in Hindi - नाड़ी ज्योतिष सेवाएं">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-8 text-gray-800">
          नाड़ी ज्योतिष (Nadi Jyotish in Hindi)
        </h1>
        
        <p class="text-xl text-center text-gray-600 mb-12">
          हिंदी में नाड़ी ज्योतिष परामर्श सेवाएं
        </p>
        
        <div class="space-y-8 text-lg leading-relaxed">
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8 text-gray-700">
            <p class="mb-4">
              नाड़ी ज्योतिष एक प्राचीन भविष्यवाणी विज्ञान है जो हजारों साल पुरानी ताड़पत्र पांडुलिपियों पर आधारित है। महान ऋषि अगस्त्य और अन्य सिद्धों ने आपके जीवन के बारे में भविष्यवाणियां लिखी हैं।
            </p>
            <p>
              वैथीस्वरन कोइल तमिलनाडु में स्थित सबसे प्रामाणिक नाड़ी ज्योतिष केंद्र है। हम हिंदी में पूर्ण परामर्श सेवाएं प्रदान करते हैं।
            </p>
          </div>
          
          <div class="bg-white border-2 border-primary rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">हमारी सेवाएं</h2>
            <ul class="space-y-3 text-gray-700">
              <li>✓ अगस्त्य नाड़ी ज्योतिष</li>
              <li>✓ शिव नाड़ी ज्योतिष</li>
              <li>✓ भृगु नाड़ी ज्योतिष</li>
              <li>✓ ऑनलाइन परामर्श हिंदी में</li>
              <li>✓ उपचारात्मक समाधान और पूजा</li>
              <li>✓ जीवन मार्गदर्शन</li>
            </ul>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">नाड़ी ज्योतिष क्या बताता है?</h2>
            <div class="space-y-4 text-gray-700">
              <p>✓ आपके पिछले जन्मों के कर्म</p>
              <p>✓ वर्तमान जीवन की चुनौतियां और समाधान</p>
              <p>✓ भविष्य की घटनाओं की सटीक भविष्यवाणी</p>
              <p>✓ करियर, विवाह, स्वास्थ्य संबंधी मार्गदर्शन</p>
              <p>✓ आध्यात्मिक विकास और मोक्ष का मार्ग</p>
            </div>
          </div>
          
          <div class="bg-primary text-white rounded-lg p-8 text-center">
            <h2 class="text-2xl font-bold mb-4">संपर्क करें</h2>
            <p class="mb-6">हिंदी में परामर्श के लिए आज ही संपर्क करें</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="tel:+919500639334" class="bg-white text-primary px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition-colors">
                कॉल करें: +91 95006 39334
              </a>
              <a href="/contact" class="border-2 border-white text-white px-8 py-3 rounded-full font-semibold hover:bg-white hover:text-primary transition-colors">
                संपर्क फॉर्म
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
