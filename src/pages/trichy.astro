---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Nadi Astrology in Trichy - Srirangam Center">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-12 text-gray-800">
          Nadi Astrology Center in Trichy
        </h1>
        
        <div class="space-y-8">
          <div class="text-gray-700 text-lg leading-relaxed">
            <p class="mb-6">
              Our Nadi Astrology center in Trichy (Tiruchirappalli) provides convenient access to authentic Nadi readings for seekers in and around the city. Located in the sacred area of Srirangam, our center maintains the same authenticity and accuracy as traditional Vaitheeswaran Koil readings.
            </p>
          </div>
          
          <div class="bg-primary/10 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">Our Trichy Center</h2>
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h3 class="text-xl font-bold mb-4 text-primary">Address</h3>
                <div class="space-y-2 text-gray-700">
                  <p>B14/27, EVS Street</p>
                  <p>Renga Nagar</p>
                  <p>KVB Bank Upstairs</p>
                  <p>Srirangam, Trichy - 620006</p>
                </div>
              </div>
              <div>
                <h3 class="text-xl font-bold mb-4 text-primary">Contact Details</h3>
                <div class="space-y-2 text-gray-700">
                  <p><a href="tel:+919500639334" class="hover:text-primary">+91 95006 39334</a></p>
                  <p><a href="tel:+919842020237" class="hover:text-primary">+91 98420 20237</a></p>
                  <p><a href="mailto:ma.thillaimani@gmail.com" class="hover:text-primary">ma.thillaimani@gmail.com</a></p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">Services Available in Trichy</h2>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-xl font-bold text-primary mb-3">In-Person Consultation</h3>
                <p class="text-gray-700">Visit our center for traditional palm leaf reading with thumb impression matching</p>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-xl font-bold text-primary mb-3">Online Consultation</h3>
                <p class="text-gray-700">Get accurate readings from your home via phone or video call</p>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-xl font-bold text-primary mb-3">Remedial Services</h3>
                <p class="text-gray-700">Poojas, homams, and other spiritual remedies based on your reading</p>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="text-xl font-bold text-primary mb-3">Follow-up Guidance</h3>
                <p class="text-gray-700">Continued support and clarification for your spiritual journey</p>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-r from-primary to-secondary text-white rounded-lg p-8 text-center">
            <h2 class="text-3xl font-bold mb-4">Why Choose Our Trichy Center?</h2>
            <ul class="space-y-3 text-left max-w-2xl mx-auto">
              <li class="flex items-start">
                <span class="text-2xl mr-3">✓</span>
                <span>Convenient location in the heart of Srirangam</span>
              </li>
              <li class="flex items-start">
                <span class="text-2xl mr-3">✓</span>
                <span>Same authentic palm leaves from Vaitheeswaran Koil</span>
              </li>
              <li class="flex items-start">
                <span class="text-2xl mr-3">✓</span>
                <span>Expert Nadi readers with 25+ years experience</span>
              </li>
              <li class="flex items-start">
                <span class="text-2xl mr-3">✓</span>
                <span>Multilingual services (Tamil, English, Hindi, Telugu, Malayalam)</span>
              </li>
              <li class="flex items-start">
                <span class="text-2xl mr-3">✓</span>
                <span>24x7 availability for appointments</span>
              </li>
            </ul>
          </div>
        </div>
        
        <div class="text-center mt-12">
          <a href="/contact" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-secondary transition-colors">
            Visit Our Trichy Center
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
