---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Nadi Astrology in Telugu - నాడీ జ్యోతిష్యం">
  <Header />
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-center mb-8 text-gray-800">
          నాడీ జ్యోతిష్యం (Nadi Jyothishyam in Telugu)
        </h1>
        
        <p class="text-xl text-center text-gray-600 mb-12">
          తెలుగులో నాడీ జ్యోతిష్య సేవలు
        </p>
        
        <div class="space-y-8 text-lg leading-relaxed">
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg p-8 text-gray-700">
            <p class="mb-4">
              నాడీ జ్యోతిష్యం అనేది వేల సంవత్సరాల క్రితం మహర్షులు తాటాకు ఆకులపై వ్రాసిన ఒక దివ్య జ్యోతిష్య విధానం. అగస్త్య మహర్షి మరియు ఇతర సిద్ధ పురుషులు మీ జీవితం గురించి ముందే భవిష్యవాణులు చేసారు.
            </p>
            <p>
              వైదీశ్వరన్ కోయిల్ తమిళనాడులో ఉన్న అత్యంత ప్రామాణికమైన నాడీ జ్యోతిష్య కేంద్రం. మేము తెలుగులో పూర్తి సేవలను అందిస్తాము.
            </p>
          </div>
          
          <div class="bg-white border-2 border-primary rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">మా సేవలు</h2>
            <ul class="space-y-3 text-gray-700">
              <li>✓ అగస్త్య నాడీ జ్యోతిష్యం</li>
              <li>✓ శివ నాడీ జ్యోతిష్యం</li>
              <li>✓ భృగు నాడీ జ్యోతిష్యం</li>
              <li>✓ తెలుగులో ఆన్‌లైన్ సంప్రదింపులు</li>
              <li>✓ పరిహార పూజలు మరియు హోమాలు</li>
              <li>✓ జీవిత మార్గదర్శకత్వం</li>
            </ul>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-8">
            <h2 class="text-3xl font-bold mb-6 text-gray-800">నాడీ జ్యోతిష్యం ఎలా పనిచేస్తుంది?</h2>
            <p class="text-gray-700 mb-4">
              మీ బొటనవేలు ముద్ర ఆధారంగా మీ కోసం ఉన్న తాటాకు ఆకు కనుగొనబడుతుంది. తరువాత ఆ ఆకులో ఉన్న సమాచారం తెలుగులో చదివి వివరించబడుతుంది.
            </p>
            <p class="text-gray-700">
              గత జన్మ కర్మలు, ప్రస్తుత జీవిత పరిస్థితులు, భవిష్యత్ అంచనాలు మరియు పరిహార మార్గాలు వివరంగా చెప్పబడతాయి.
            </p>
          </div>
          
          <div class="bg-primary text-white rounded-lg p-8 text-center">
            <h2 class="text-2xl font-bold mb-4">సంప్రదించండి</h2>
            <p class="mb-6">మీ నాడీ జ్యోతిష్య పఠనం కోసం నేడే సంప్రదించండి</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="tel:+919500639334" class="bg-white text-primary px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition-colors">
                కాల్ చేయండి: +91 95006 39334
              </a>
              <a href="/contact" class="border-2 border-white text-white px-8 py-3 rounded-full font-semibold hover:bg-white hover:text-primary transition-colors">
                సంప్రదింపు ఫారం
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
  <WhatsAppButton />
</Layout>
